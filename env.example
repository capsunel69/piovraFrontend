# Capsuna frontend (Vite). All API/auth calls go directly to Piovra.
# Set this to the public Piovra origin (the same one configured in
# GOOGLE_OAUTH_REDIRECT_URI on the server) so the SPA can hit /auth/google
# and /v1/* with the session cookie attached.
#
# Example: https://piovra.your-domain.com
VITE_PIOVRA_BASE_URL=

# Tenor API key for GIF search in the work chat composer. Optional — without
# it, the GIF picker shows a hint and stays disabled. Get a free key at
# https://developers.google.com/tenor/guides/quickstart
VITE_TENOR_API_KEY=

# NODE_ENV is set by Netlify automatically; nothing else lives here.
